const GRAPH_VERSION =
  process.env.FACEBOOK_GRAPH_API_VERSION ||
  process.env.META_GRAPH_API_VERSION ||
  "v25.0";

const GRAPH_BASE = `https://graph.facebook.com/${GRAPH_VERSION}`;

function requiredEnv(name: string) {
  const value = process.env[name]?.trim();
  if (!value) throw new Error(`${name} is missing`);
  return value;
}

function getSupabaseRest() {
  const url =
    process.env.SUPABASE_URL ||
    process.env.NEXT_PUBLIC_SUPABASE_URL;

  const serviceKey =
    process.env.SUPABASE_SERVICE_ROLE_KEY ||
    process.env.SUPABASE_SERVICE_KEY;

  if (!url || !serviceKey) {
    throw new Error("Supabase service env is missing");
  }

  return {
    url: url.replace(/\/$/, ""),
    serviceKey,
  };
}

async function supabaseFetch(path: string, init: RequestInit = {}) {
  const { url, serviceKey } = getSupabaseRest();

  const response = await fetch(`${url}/rest/v1${path}`, {
    ...init,
    headers: {
      apikey: serviceKey,
      Authorization: `Bearer ${serviceKey}`,
      "Content-Type": "application/json",
      ...(init.headers || {}),
    },
    cache: "no-store",
  });

  const text = await response.text();

  let data: any = null;
  try {
    data = text ? JSON.parse(text) : null;
  } catch {
    data = text;
  }

  if (!response.ok) {
    throw new Error(
      typeof data === "string"
        ? data
        : data?.message || `Supabase request failed: ${response.status}`
    );
  }

  return data;
}

export function getFacebookOAuthConfig() {
  return {
    appId: requiredEnv("FACEBOOK_APP_ID"),
    appSecret: requiredEnv("FACEBOOK_APP_SECRET"),
    redirectUri:
      process.env.FACEBOOK_REDIRECT_URI ||
      "https://getreviewintel.com/api/auth/facebook/callback",
    pageId: requiredEnv("FACEBOOK_PAGE_ID"),
    graphVersion: GRAPH_VERSION,
  };
}

export function getFacebookScopes() {
  return [
    "pages_show_list",
    "pages_read_engagement",
    "pages_manage_posts",
    "pages_manage_metadata",
  ];
}

export function buildFacebookOAuthUrl(state: string) {
  const config = getFacebookOAuthConfig();
  const url = new URL(`https://www.facebook.com/${config.graphVersion}/dialog/oauth`);

  url.searchParams.set("client_id", config.appId);
  url.searchParams.set("redirect_uri", config.redirectUri);
  url.searchParams.set("state", state);
  url.searchParams.set("response_type", "code");
  url.searchParams.set("scope", getFacebookScopes().join(","));

  return url.toString();
}

export async function exchangeFacebookCodeForUserToken(code: string) {
  const config = getFacebookOAuthConfig();
  const url = new URL(`${GRAPH_BASE}/oauth/access_token`);

  url.searchParams.set("client_id", config.appId);
  url.searchParams.set("client_secret", config.appSecret);
  url.searchParams.set("redirect_uri", config.redirectUri);
  url.searchParams.set("code", code);

  const response = await fetch(url.toString(), { cache: "no-store" });
  const data = await response.json();

  if (!response.ok || !data.access_token) {
    throw new Error(data?.error?.message || "Facebook code exchange failed");
  }

  return data as {
    access_token: string;
    token_type?: string;
    expires_in?: number;
  };
}

export async function exchangeForLongLivedUserToken(shortLivedUserToken: string) {
  const config = getFacebookOAuthConfig();
  const url = new URL(`${GRAPH_BASE}/oauth/access_token`);

  url.searchParams.set("grant_type", "fb_exchange_token");
  url.searchParams.set("client_id", config.appId);
  url.searchParams.set("client_secret", config.appSecret);
  url.searchParams.set("fb_exchange_token", shortLivedUserToken);

  const response = await fetch(url.toString(), { cache: "no-store" });
  const data = await response.json();

  if (!response.ok || !data.access_token) {
    // If exchange fails, fallback to short-lived token so the admin still gets a clear diagnostic.
    return {
      access_token: shortLivedUserToken,
      token_type: "bearer",
      expires_in: undefined,
      exchange_warning: data?.error?.message || "Long-lived token exchange failed",
    };
  }

  return data as {
    access_token: string;
    token_type?: string;
    expires_in?: number;
  };
}

export async function getFacebookPages(userAccessToken: string) {
  const url = new URL(`${GRAPH_BASE}/me/accounts`);
  url.searchParams.set("fields", "id,name,access_token,tasks,perms");
  url.searchParams.set("access_token", userAccessToken);

  const response = await fetch(url.toString(), { cache: "no-store" });
  const data = await response.json();

  if (!response.ok) {
    throw new Error(data?.error?.message || "Failed to fetch Facebook pages");
  }

  return Array.isArray(data.data) ? data.data : [];
}

export async function verifyFacebookPageToken(pageId: string, pageToken: string) {
  const url = new URL(`${GRAPH_BASE}/${pageId}`);
  url.searchParams.set("fields", "id,name");
  url.searchParams.set("access_token", pageToken);

  const response = await fetch(url.toString(), { cache: "no-store" });
  const data = await response.json();

  if (!response.ok) {
    throw new Error(data?.error?.message || "Facebook page token verification failed");
  }

  return data as { id: string; name: string };
}

export async function storeFacebookConnection(input: {
  pageId: string;
  pageName: string;
  pageAccessToken: string;
  tokenType?: string;
  expiresIn?: number;
  scopes?: string[];
  metadata?: Record<string, any>;
}) {
  const expiresAt = input.expiresIn
    ? new Date(Date.now() + input.expiresIn * 1000).toISOString()
    : null;

  await supabaseFetch("/social_connections?on_conflict=provider", {
    method: "POST",
    headers: {
      Prefer: "resolution=merge-duplicates,return=representation",
    },
    body: JSON.stringify({
      provider: "facebook",
      account_id: input.pageId,
      account_name: input.pageName,
      access_token: input.pageAccessToken,
      token_type: input.tokenType || "bearer",
      expires_at: expiresAt,
      scopes: input.scopes || getFacebookScopes(),
      metadata: input.metadata || {},
      is_connected: true,
      updated_at: new Date().toISOString(),
    }),
  });
}

export async function getStoredFacebookPageToken() {
  try {
    const rows = await supabaseFetch(
      "/social_connections?provider=eq.facebook&is_connected=eq.true&select=access_token,account_id,account_name,expires_at&limit=1",
      { method: "GET" }
    );

    const row = Array.isArray(rows) ? rows[0] : null;

    if (!row?.access_token) return null;

    return {
      accessToken: row.access_token as string,
      pageId: row.account_id as string | null,
      pageName: row.account_name as string | null,
      expiresAt: row.expires_at as string | null,
    };
  } catch {
    return null;
  }
}

export async function disconnectFacebookConnection() {
  await supabaseFetch("/social_connections?provider=eq.facebook", {
    method: "PATCH",
    headers: {
      Prefer: "return=minimal",
    },
    body: JSON.stringify({
      is_connected: false,
      access_token: null,
      refresh_token: null,
      updated_at: new Date().toISOString(),
    }),
  });
}

export async function getFacebookPageAccessTokenForPosting() {
  const stored = await getStoredFacebookPageToken();

  if (stored?.accessToken) {
    return {
      accessToken: stored.accessToken,
      pageId: stored.pageId || process.env.FACEBOOK_PAGE_ID || "",
      source: "connected-facebook-oauth",
    };
  }

  return {
    accessToken: process.env.FACEBOOK_PAGE_ACCESS_TOKEN || "",
    pageId: process.env.FACEBOOK_PAGE_ID || "",
    source: "env-fallback",
  };
}

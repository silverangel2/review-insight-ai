/* =========================================================
   ReviewIntel Tiny Mobile Nav
   Shows a small sticky nav only in Mobile Vertical / phone Auto.
   Desktop unchanged.
   ========================================================= */

.ri-mobile-tiny-nav {
  display: none;
}

/* Mobile mode */
html[data-layout-mode="mobile"] .ri-mobile-tiny-nav {
  position: sticky;
  top: 0;
  z-index: 9998;
  display: block;
  width: 100%;
  max-width: 430px;
  margin-left: auto;
  margin-right: auto;
  padding: 0.32rem 0.38rem;
  background: rgba(255, 255, 255, 0.92);
  border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(14px);
}

/* Auto mode on real phone screens */
@media (max-width: 640px) {
  html[data-layout-mode="auto"] .ri-mobile-tiny-nav {
    position: sticky;
    top: 0;
    z-index: 9998;
    display: block;
    width: 100%;
    max-width: 430px;
    margin-left: auto;
    margin-right: auto;
    padding: 0.32rem 0.38rem;
    background: rgba(255, 255, 255, 0.92);
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    backdrop-filter: blur(14px);
  }
}

.ri-mobile-tiny-nav-scroll {
  display: flex;
  gap: 0.32rem;
  overflow-x: auto;
  overscroll-behavior-x: contain;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}

.ri-mobile-tiny-nav-scroll::-webkit-scrollbar {
  display: none;
}

.ri-mobile-tiny-nav a {
  flex: 0 0 auto;
  border-radius: 999px;
  padding: 0.28rem 0.52rem;
  font-size: 0.56rem;
  line-height: 1;
  font-weight: 900;
  letter-spacing: -0.01em;
  color: #475569;
  background: rgba(15, 23, 42, 0.055);
  text-decoration: none;
  white-space: nowrap;
}

.ri-mobile-tiny-nav a.active {
  color: white;
  background: linear-gradient(135deg, #7c3aed, #06b6d4);
  box-shadow: 0 6px 16px rgba(15, 23, 42, 0.16);
}

.dark .ri-mobile-tiny-nav {
  background: rgba(2, 6, 23, 0.9);
  border-bottom-color: rgba(255, 255, 255, 0.1);
}

.dark .ri-mobile-tiny-nav a {
  color: #cbd5e1;
  background: rgba(255, 255, 255, 0.08);
}

.dark .ri-mobile-tiny-nav a.active {
  color: white;
}

/* Prevent the tiny nav from being shrunk by previous mobile page patches */
html[data-layout-mode="mobile"] .ri-mobile-tiny-nav a,
html[data-layout-mode="auto"] .ri-mobile-tiny-nav a {
  font-size: 0.56rem !important;
  min-height: auto !important;
  padding: 0.28rem 0.52rem !important;
  border-radius: 999px !important;
}

/* Add a little breathing room below tiny nav */
html[data-layout-mode="mobile"] .ri-mobile-tiny-nav + *,
html[data-layout-mode="auto"] .ri-mobile-tiny-nav + * {
  margin-top: 0.15rem;
}


/* =========================================================
   Tiny Mobile Nav Mirror Top Nav Fix
   Make mobile quick nav match the visible desktop top nav.
   ========================================================= */

.ri-mobile-tiny-nav-scroll button {
  flex: 0 0 auto;
  border: 0;
  border-radius: 999px;
  padding: 0.28rem 0.52rem;
  font-size: 0.56rem;

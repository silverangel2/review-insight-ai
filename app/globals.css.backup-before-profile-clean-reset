@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  color-scheme: light;
  background: #f2fbff;
  --ri-ease: cubic-bezier(0.22, 1, 0.36, 1);
  --ri-fast: 180ms;
  --ri-medium: 360ms;
}

.dark {
  color-scheme: dark;
  background: #050816;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-height: 100vh;
  background:
    radial-gradient(circle at 10% 8%, rgba(8, 183, 168, 0.16), transparent 26%),
    radial-gradient(circle at 88% 10%, rgba(255, 178, 56, 0.22), transparent 24%),
    radial-gradient(circle at 72% 80%, rgba(35, 86, 163, 0.16), transparent 28%),
    linear-gradient(180deg, rgba(250, 254, 255, 0.96), rgba(241, 247, 255, 1)),
    #f2fbff;
  color: #172033;
  font-family:
    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.dark body {
  background:
    radial-gradient(circle at top left, rgba(8, 183, 168, 0.22), transparent 32%),
    radial-gradient(circle at top right, rgba(255, 178, 56, 0.13), transparent 26%),
    radial-gradient(circle at 74% 72%, rgba(118, 87, 184, 0.22), transparent 34%),
    #050816;
  color: #e5eefb;
}

::selection {
  background: rgba(15, 159, 154, 0.18);
}

.ri-scan-grid {
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
  background-size: 34px 34px;
  mask-image: linear-gradient(180deg, black, transparent 82%);
}

.ri-scan-beam {
  animation: scanBeam 5.5s ease-in-out infinite;
  background: linear-gradient(180deg, transparent, rgba(15, 159, 154, 0.22), transparent);
  filter: blur(2px);
}

.ri-shimmer {
  background-size: 220% 100%;
  animation: shimmerSweep 6s ease-in-out infinite;
}

.ri-reveal-pop {
  animation: revealPop var(--ri-medium) var(--ri-ease) both;
  backface-visibility: hidden;
  will-change: opacity, transform;
}

.ri-premium-motion,
.ri-reveal-pop,
a,
button {
  transition-duration: var(--ri-fast);
  transition-timing-function: var(--ri-ease);
}

.ri-score-orbit {
  position: relative;
  animation: scoreFloat 4.5s ease-in-out infinite;
}

.ri-score-orbit::before,
.ri-score-orbit::after {
  position: absolute;
  content: "";
  border-radius: 999px;
  pointer-events: none;
}

.ri-score-orbit::before {
  inset: -14px;
  border: 2px dashed rgba(255, 255, 255, 0.46);
  animation: orbitSpin 10s linear infinite;
}

.ri-score-orbit::after {
  inset: 16px;
  border: 1px solid rgba(255, 255, 255, 0.3);
  animation: orbitSpin 7s linear infinite reverse;
}

.ri-result-firework {
  width: 9rem;
  height: 9rem;
  background:
    repeating-conic-gradient(from 0deg, rgba(255, 255, 255, 0.9) 0deg 4deg, transparent 4deg 18deg),
    radial-gradient(circle, rgba(255, 255, 255, 0.5) 0 2px, transparent 3px);
  mask-image: radial-gradient(circle, transparent 0 18%, black 19% 48%, transparent 49%);
  animation: fireworkSpin 9s linear infinite;
}

.ri-mini-bot {
  min-height: 13rem;
}

.ri-mini-bot-head {
  position: relative;
  display: flex;
  width: 8.5rem;
  height: 6rem;
  align-items: center;
  justify-content: center;
  gap: 1.1rem;
  margin: 0 auto;
  border: 2px solid rgba(255, 255, 255, 0.35);
  border-radius: 1.6rem;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(204, 252, 255, 0.84)),
    #ffffff;
  box-shadow: 0 18px 60px rgba(8, 183, 168, 0.25);
  animation: botNod 3s ease-in-out infinite;
}

.ri-mini-bot-head::before {
  position: absolute;
  top: -1.4rem;
  left: 50%;
  width: 2px;
  height: 1.4rem;
  content: "";
  background: rgba(255, 255, 255, 0.75);
}

.ri-mini-bot-head::after {
  position: absolute;
  top: -1.75rem;
  left: calc(50% - 0.35rem);
  width: 0.7rem;
  height: 0.7rem;
  content: "";
  border-radius: 999px;
  background: #ffb238;
  box-shadow: 0 0 22px rgba(255, 178, 56, 0.9);
}

.ri-mini-bot-head span {
  width: 1.15rem;
  height: 1.15rem;
  border-radius: 999px;
  background: #172033;
  box-shadow: 0 0 0 7px rgba(8, 183, 168, 0.16);
  animation: botBlink 4.6s ease-in-out infinite;
}

.ri-hero-aurora {
  background:
    radial-gradient(circle at 18% 24%, rgba(15, 159, 154, 0.28), transparent 28%),
    radial-gradient(circle at 72% 18%, rgba(118, 87, 184, 0.26), transparent 30%),
    radial-gradient(circle at 82% 76%, rgba(214, 139, 31, 0.16), transparent 26%),
    linear-gradient(135deg, rgba(5, 8, 22, 0.65), rgba(23, 32, 51, 0.86));
  animation: heroAurora 12s ease-in-out infinite;
}

.ri-orb-haze {
  background:
    radial-gradient(circle at 50% 28%, rgba(15, 159, 154, 0.22), transparent 30%),
    radial-gradient(circle at 40% 64%, rgba(118, 87, 184, 0.24), transparent 34%),
    radial-gradient(circle at 72% 58%, rgba(214, 139, 31, 0.12), transparent 28%);
  animation: orbHaze 7s ease-in-out infinite;
}

.ri-ai-orb {
  position: relative;
  display: grid;
  width: 8.5rem;
  height: 8.5rem;
  place-items: center;
  animation: orbVibrate 1.8s ease-in-out infinite;
  filter: drop-shadow(0 0 42px rgba(15, 159, 154, 0.55));
}

.ri-ai-orb-core {
  position: absolute;
  inset: 1.1rem;
  border-radius: 999px;
  background:
    radial-gradient(circle at 32% 26%, rgba(255, 255, 255, 0.98), rgba(180, 255, 250, 0.9) 18%, transparent 19%),
    radial-gradient(circle at 68% 68%, rgba(118, 87, 184, 0.65), transparent 24%),
    radial-gradient(circle at 48% 48%, #d9fffb, #0f9f9a 52%, #2356a3);
  box-shadow:
    inset -16px -20px 38px rgba(5, 8, 22, 0.45),
    inset 10px 12px 24px rgba(255, 255, 255, 0.28),
    0 0 68px rgba(15, 159, 154, 0.6);
}

.ri-ai-orb-ring {
  position: absolute;
  inset: 0;
  border: 1px solid rgba(255, 255, 255, 0.42);
  border-radius: 999px;
  animation: orbPulse 2.6s ease-out infinite;
}

.ri-ai-orb-ring-delay {
  animation-delay: 1.1s;
  border-color: rgba(118, 87, 184, 0.5);
}

.ri-progress-ring {
  animation: progressGlow 5.2s ease-in-out infinite;
  border-radius: 999px;
}

.ri-progress-segment {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0.34rem;
  height: 1.2rem;
  margin-top: -0.6rem;
  margin-left: -0.17rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.18);
  box-shadow: 0 0 18px rgba(8, 183, 168, 0);
  animation: segmentFill 2.9s ease-in-out infinite;
}

.ri-pixie-field span,
.ri-loading-particles span {
  position: absolute;
  width: 0.34rem;
  height: 0.34rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.86);
  box-shadow:
    0 0 16px rgba(143, 255, 244, 0.7),
    0 0 30px rgba(118, 87, 184, 0.34);
  animation: pixieDrift 7.8s ease-in-out infinite;
}

.ri-pixie-field span:nth-child(3n),
.ri-loading-particles span:nth-child(3n) {
  background: #8ffff4;
  box-shadow: 0 0 20px rgba(143, 255, 244, 0.9);
}

.ri-pixie-field span:nth-child(4n),
.ri-loading-particles span:nth-child(4n) {
  background: #ffd2e3;
  box-shadow: 0 0 22px rgba(255, 93, 143, 0.58);
}

.ri-home-orb {
  position: absolute;
  width: 18rem;
  height: 18rem;
  border-radius: 999px;
  opacity: 0.72;
  filter: blur(18px);
  mix-blend-mode: screen;
  pointer-events: none;
}

.ri-home-orb-one {
  left: 62%;
  top: 14%;
  background: radial-gradient(circle at 32% 28%, #ffffff, #8ffff4 18%, #2356a3 54%, transparent 72%);
  animation: homeOrbOne 14s ease-in-out infinite;
}

.ri-home-orb-two {
  left: 8%;
  bottom: 10%;
  background: radial-gradient(circle at 62% 35%, #ffffff, #ffd2e3 22%, #7657b8 55%, transparent 74%);
  animation: homeOrbTwo 16s ease-in-out infinite;
}

.ri-scan-fog {
  background:
    radial-gradient(circle at 18% 30%, rgba(8, 183, 168, 0.24), transparent 28%),
    radial-gradient(circle at 78% 24%, rgba(118, 87, 184, 0.25), transparent 30%),
    radial-gradient(circle at 60% 82%, rgba(255, 93, 143, 0.16), transparent 30%),
    radial-gradient(circle at 38% 68%, rgba(255, 255, 255, 0.12), transparent 34%);
  animation: scanFogShift 9s ease-in-out infinite;
}

.ri-loading-particles span {
  width: 0.28rem;
  height: 0.28rem;
  animation-name: loadingParticleDrift;
}

.ri-energy-wave {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 44rem;
  height: 44rem;
  border-radius: 999px;
  border: 1px solid rgba(143, 255, 244, 0.15);
  box-shadow:
    inset 0 0 70px rgba(8, 183, 168, 0.08),
    0 0 90px rgba(118, 87, 184, 0.12);
  pointer-events: none;
  transform: translate(-50%, -50%);
  animation: energyWave 7s ease-in-out infinite;
}

.ri-energy-wave-two {
  width: 58rem;
  height: 58rem;
  border-color: rgba(255, 178, 56, 0.12);
  animation-delay: 1.8s;
  animation-duration: 9s;
}

.ri-scan-corner {
  position: absolute;
  width: 9rem;
  height: 9rem;
  border-radius: 999px;
  opacity: 0.76;
  filter: blur(16px);
  pointer-events: none;
}

.ri-scan-corner-a {
  left: -3rem;
  top: -3rem;
  background: rgba(8, 183, 168, 0.42);
  animation: cornerPulse 5.5s ease-in-out infinite;
}

.ri-scan-corner-b {
  right: -3rem;
  top: -2rem;
  background: rgba(118, 87, 184, 0.42);
  animation: cornerPulse 6.1s ease-in-out infinite reverse;
}

.ri-scan-corner-c {
  bottom: -3rem;
  left: 4rem;
  background: rgba(255, 93, 143, 0.28);
  animation: cornerPulse 6.8s ease-in-out infinite;
}

.ri-scan-corner-d {
  right: 3rem;
  bottom: -3rem;
  background: rgba(255, 178, 56, 0.3);
  animation: cornerPulse 7.2s ease-in-out infinite reverse;
}

@keyframes scanBeam {
  0% {
    transform: translateY(-100%);
    opacity: 0;
  }
  22% {
    opacity: 1;
  }
  74% {
    opacity: 0.85;
  }
  100% {
    transform: translateY(440%);
    opacity: 0;
  }
}

@keyframes heroAurora {
  0%,
  100% {
    filter: saturate(1) brightness(1);
    transform: scale(1);
  }
  50% {
    filter: saturate(1.18) brightness(1.08);
    transform: scale(1.03);
  }
}

@keyframes orbHaze {
  0%,
  100% {
    filter: hue-rotate(0deg) blur(0);
    opacity: 0.9;
  }
  50% {
    filter: hue-rotate(22deg) blur(1px);
    opacity: 1;
  }
}

@keyframes orbPulse {
  0% {
    opacity: 0.85;
    transform: scale(0.72) rotate(0deg);
  }
  100% {
    opacity: 0;
    transform: scale(1.45) rotate(18deg);
  }
}

@keyframes orbVibrate {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  20% {
    transform: translate3d(1px, -2px, 0) scale(1.02);
  }
  40% {
    transform: translate3d(-2px, 1px, 0) scale(0.99);
  }
  60% {
    transform: translate3d(2px, 2px, 0) scale(1.03);
  }
  80% {
    transform: translate3d(-1px, -1px, 0) scale(1);
  }
}

@keyframes segmentFill {
  0%,
  18% {
    background: rgba(255, 255, 255, 0.16);
    box-shadow: 0 0 14px rgba(8, 183, 168, 0);
    opacity: 0.46;
  }
  45%,
  78% {
    background: linear-gradient(180deg, #ffffff, #8ffff4 48%, #ffdc8a);
    box-shadow: 0 0 24px rgba(8, 183, 168, 0.9);
    opacity: 1;
  }
  100% {
    background: rgba(255, 255, 255, 0.2);
    box-shadow: 0 0 14px rgba(8, 183, 168, 0.1);
    opacity: 0.62;
  }
}

@keyframes progressGlow {
  0%,
  100% {
    filter: drop-shadow(0 0 18px rgba(8, 183, 168, 0.24));
  }
  50% {
    filter: drop-shadow(0 0 36px rgba(255, 178, 56, 0.45));
  }
}

@keyframes pixieDrift {
  0%,
  100% {
    opacity: 0.28;
    transform: translate3d(0, 0, 0) scale(0.8);
  }
  45% {
    opacity: 1;
    transform: translate3d(24px, -32px, 0) scale(1.28);
  }
  72% {
    opacity: 0.78;
    transform: translate3d(-18px, 20px, 0) scale(0.92);
  }
}

@keyframes loadingParticleDrift {
  0%,
  100% {
    opacity: 0.2;
    transform: translate3d(0, 0, 0) scale(0.8);
  }
  50% {
    opacity: 0.95;
    transform: translate3d(34px, -44px, 0) scale(1.22);
  }
}

@keyframes homeOrbOne {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    transform: translate3d(-42px, 36px, 0) scale(1.08);
  }
}

@keyframes homeOrbTwo {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(0.94);
  }
  50% {
    transform: translate3d(52px, -28px, 0) scale(1.06);
  }
}

@keyframes scanFogShift {
  0%,
  100% {
    filter: hue-rotate(0deg) saturate(1);
    transform: scale(1);
  }
  50% {
    filter: hue-rotate(18deg) saturate(1.18);
    transform: scale(1.04);
  }
}

@keyframes energyWave {
  0%,
  100% {
    opacity: 0.18;
    transform: translate(-50%, -50%) scale(0.82) rotate(0deg);
  }
  48% {
    opacity: 0.44;
    transform: translate(-50%, -50%) scale(1.04) rotate(14deg);
  }
}

@keyframes cornerPulse {
  0%,
  100% {
    opacity: 0.36;
    transform: translate3d(0, 0, 0) scale(0.92);
  }
  50% {
    opacity: 0.78;
    transform: translate3d(18px, 12px, 0) scale(1.12);
  }
}

@keyframes shimmerSweep {
  0%,
  100% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
}

@keyframes revealPop {
  0% {
    opacity: 0;
    transform: translate3d(0, 10px, 0) scale(0.992);
  }
  100% {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes scoreFloat {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8px);
  }
}

@keyframes orbitSpin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes fireworkSpin {
  0% {
    opacity: 0.72;
    transform: rotate(0deg) scale(0.92);
  }
  50% {
    opacity: 1;
    transform: rotate(180deg) scale(1.04);
  }
  100% {
    opacity: 0.72;
    transform: rotate(360deg) scale(0.92);
  }
}

@keyframes botNod {
  0%,
  100% {
    transform: translateY(0) rotate(-1deg);
  }
  50% {
    transform: translateY(-6px) rotate(1deg);
  }
}

@keyframes botBlink {
  0%,
  88%,
  100% {
    transform: scaleY(1);
  }
  92% {
    transform: scaleY(0.12);
  }
}

.ri-platform-orbit {
  --orbit-radius: 13rem;
  position: relative;
  min-height: 36rem;
  overflow: hidden;
  border: 1px solid rgba(143, 255, 244, 0.18);
  border-radius: 2rem;
  background:
    linear-gradient(rgba(143, 255, 244, 0.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(143, 255, 244, 0.055) 1px, transparent 1px),
    radial-gradient(circle at 50% 50%, rgba(8, 183, 168, 0.26), transparent 22%),
    radial-gradient(circle at 20% 24%, rgba(118, 87, 184, 0.24), transparent 28%),
    radial-gradient(circle at 78% 76%, rgba(255, 178, 56, 0.16), transparent 30%),
    linear-gradient(135deg, rgba(5, 8, 22, 0.96), rgba(12, 32, 62, 0.94));
  background-size: 38px 38px, 38px 38px, auto, auto, auto, auto;
  box-shadow: 0 34px 110px rgba(35, 86, 163, 0.26);
}

.ri-platform-spark {
  position: absolute;
  width: 18rem;
  height: 18rem;
  border-radius: 999px;
  filter: blur(34px);
  opacity: 0.42;
  pointer-events: none;
}

.ri-platform-spark-a {
  left: 8%;
  top: 12%;
  background: radial-gradient(circle, rgba(8, 183, 168, 0.45), transparent 62%);
  animation: platformSparkDrift 9s ease-in-out infinite;
}

.ri-platform-spark-b {
  right: 4%;
  bottom: 8%;
  background: radial-gradient(circle, rgba(255, 178, 56, 0.42), transparent 62%);
  animation: platformSparkDrift 10s ease-in-out infinite reverse;
}

.dark .ri-platform-orbit {
  border-color: rgba(255, 255, 255, 0.1);
  background:
    linear-gradient(rgba(143, 255, 244, 0.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(143, 255, 244, 0.055) 1px, transparent 1px),
    radial-gradient(circle at 50% 50%, rgba(8, 183, 168, 0.18), transparent 24%),
    radial-gradient(circle at 20% 24%, rgba(118, 87, 184, 0.2), transparent 28%),
    radial-gradient(circle at 78% 74%, rgba(255, 178, 56, 0.12), transparent 28%),
    #0b1220;
  background-size: 38px 38px, 38px 38px, auto, auto, auto, auto;
}

.ri-platform-orbit::before,
.ri-platform-orbit::after {
  position: absolute;
  inset: 4.5rem;
  content: "";
  border: 1px solid rgba(143, 255, 244, 0.16);
  border-radius: 999px;
  box-shadow:
    inset 0 0 34px rgba(8, 183, 168, 0.1),
    0 0 44px rgba(8, 183, 168, 0.1);
  animation: orbitSpin 18s linear infinite;
}

.ri-platform-orbit::after {
  inset: 8rem;
  border-color: rgba(118, 87, 184, 0.24);
  animation-duration: 12s;
  animation-direction: reverse;
}

.ri-platform-scanline {
  position: absolute;
  inset: 0;
  background: linear-gradient(100deg, transparent 0 42%, rgba(143, 255, 244, 0.16) 48%, transparent 56% 100%);
  filter: blur(4px);
  opacity: 0.7;
  transform: translateX(-120%);
  animation: platformScanSweep 5.5s ease-in-out infinite;
  pointer-events: none;
}

.ri-platform-center {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  display: grid;
  width: 10rem;
  height: 10rem;
  place-items: center;
  border: 1px solid rgba(143, 255, 244, 0.28);
  border-radius: 999px;
  background:
    radial-gradient(circle at 34% 24%, rgba(255, 255, 255, 0.9), transparent 9%),
    radial-gradient(circle at 50% 50%, rgba(8, 183, 168, 0.82), rgba(35, 86, 163, 0.88) 56%, rgba(5, 8, 22, 0.96));
  color: #ffffff;
  box-shadow:
    0 0 0 10px rgba(143, 255, 244, 0.04),
    0 0 70px rgba(8, 183, 168, 0.34),
    0 26px 90px rgba(8, 183, 168, 0.28);
  transform: translate(-50%, -50%);
  animation: platformCorePulse 4.8s ease-in-out infinite;
}

.ri-platform-center span {
  display: grid;
  width: 3.4rem;
  height: 3.4rem;
  place-items: center;
  border-radius: 1.2rem;
  background: rgba(255, 255, 255, 0.16);
  font-weight: 900;
}

.ri-platform-center strong {
  margin-top: -1.8rem;
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.ri-platform-center em {
  margin-top: -2.3rem;
  color: rgba(210, 245, 255, 0.74);
  font-size: 0.62rem;
  font-style: normal;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.ri-platform-node {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 3;
  display: inline-flex;
  min-width: 8.4rem;
  align-items: center;
  gap: 0.65rem;
  padding: 0.7rem 0.82rem;
  border: 1px solid color-mix(in srgb, var(--brand), white 40%);
  border-radius: 1rem;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.13), rgba(255, 255, 255, 0.04)),
    rgba(6, 14, 28, 0.84);
  box-shadow:
    0 18px 50px rgba(0, 0, 0, 0.26),
    0 0 30px color-mix(in srgb, var(--brand), transparent 74%),
    inset 0 1px 0 rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 0.78rem;
  font-weight: 900;
  text-align: center;
  backdrop-filter: blur(14px);
  transform:
    translate(-50%, -50%)
    rotate(var(--angle))
    translateY(calc(-1 * var(--orbit-radius)))
    rotate(var(--reverse-angle));
  animation: platformNodeOrbit 14s linear infinite;
  will-change: transform;
}

.dark .ri-platform-node {
  border-color: rgba(255, 255, 255, 0.12);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.13), rgba(255, 255, 255, 0.04)),
    rgba(6, 14, 28, 0.84);
  color: #ffffff;
}

.ri-platform-mark {
  display: grid;
  width: 2rem;
  height: 2rem;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 0.8rem;
  background: var(--brand);
  color: #ffffff;
  font-size: 0.9rem;
  font-weight: 950;
  box-shadow: 0 10px 28px color-mix(in srgb, var(--brand), transparent 55%);
}

@media (max-width: 700px) {
  .ri-platform-orbit {

"use client";

import { useState } from "react";

type SellerResult = {
  summary?: string;
  reviewsAnalyzed?: number;
  healthScore?: number;
  buyerSatisfaction?: number;
  refundRisk?: number;
  topComplaints?: string[];
  topPraise?: string[];
  buyerObjections?: string[];
  productFixes?: string[];
  listingFixes?: string[];
  adAngles?: string[];
  nextActions?: string[];
};

function score(value?: number) {
  if (typeof value !== "number") return "—";
  return `${Math.round(value)}/100`;
}

function battleVerdict(yourScore?: number, competitorScore?: number) {
  if (typeof yourScore !== "number" || typeof competitorScore !== "number") {
    return "Upload both CSV files to compare.";
  }

  if (yourScore === competitorScore) {
    return "Tie. Both products need a deeper complaint and advantage review.";
  }

  return yourScore > competitorScore
    ? "Your product is stronger based on review evidence."
    : "The competitor is stronger based on review evidence.";
}

function compareRisk(yourRisk?: number, competitorRisk?: number) {
  if (typeof yourRisk !== "number" || typeof competitorRisk !== "number") return "—";
  if (yourRisk === competitorRisk) return "Same refund risk";
  return yourRisk < competitorRisk ? "Your product has lower refund risk" : "Competitor has lower refund risk";
}

export default function SellerComparePage() {
  const [yourFile, setYourFile] = useState<File | null>(null);
  const [competitorFile, setCompetitorFile] = useState<File | null>(null);
  const [yourResult, setYourResult] = useState<SellerResult | null>(null);
  const [competitorResult, setCompetitorResult] = useState<SellerResult | null>(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  async function analyzeCsv(file: File) {
    const formData = new FormData();
    formData.append("file", file, file.name);
    formData.append("csv", file, file.name);
    formData.append("locale", "en");

    const response = await fetch("/api/seller-analyze", {
      method: "POST",
      body: formData,
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data?.error || "Seller analysis failed.");
    }

    return data as SellerResult;
  }

  async function runCompare() {
    if (!yourFile || !competitorFile) {
      setError("Upload CSV files for both your product and the competitor.");
      return;
    }

    setLoading(true);
    setError("");
    setYourResult(null);
    setCompetitorResult(null);

    try {
      const [yourAnalysis, competitorAnalysis] = await Promise.all([
        analyzeCsv(yourFile),
        analyzeCsv(competitorFile),
      ]);

      setYourResult(yourAnalysis);
      setCompetitorResult(competitorAnalysis);
    } catch (err) {
      setError(err instanceof Error ? err.message : "Seller compare failed.");
    } finally {
      setLoading(false);
    }
  }

  const verdict = battleVerdict(yourResult?.healthScore, competitorResult?.healthScore);
  const refundRiskWinner = compareRisk(yourResult?.refundRisk, competitorResult?.refundRisk);

  return (
    <main className="min-h-screen bg-[#f7f3ea] px-4 py-10 text-[#172033]">
      <section className="mx-auto max-w-6xl rounded-[32px] border border-[#d9e2ec] bg-white/95 p-8 shadow-sm">
        <p className="text-sm font-black uppercase tracking-[0.35em] text-teal-600">
          ReviewIntel Seller Compare
        </p>

        <h1 className="mt-3 text-4xl font-black tracking-tight md:text-5xl">
          Your Product vs Competitor.
        </h1>

        <p className="mt-4 max-w-3xl text-base font-semibold text-slate-600">
          Find out why buyers may choose your competitor instead of you. Compare complaints,
          refund risk, buyer objections, product weaknesses, listing problems, and ad angles.
        </p>

        <div className="mt-8 grid gap-5 md:grid-cols-2">
          <UploadBox
            eyebrow="Your Product CSV"
            title="Upload your product reviews"
            file={yourFile}
            onChange={setYourFile}
          />

          <UploadBox
            eyebrow="Competitor CSV"
            title="Upload competitor reviews"
            file={competitorFile}
            onChange={setCompetitorFile}
          />
        </div>

        {error && (
          <div className="mt-5 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-700">
            {error}
          </div>
        )}

        <button
          onClick={runCompare}
          disabled={loading}
          className="mt-6 w-full rounded-2xl bg-slate-900 px-6 py-4 text-base font-black text-white disabled:cursor-not-allowed disabled:bg-slate-300"
        >
          {loading ? "Comparing your product vs competitor..." : "Compare Your Product vs Competitor"}
        </button>

        {(yourResult || competitorResult) && (
          <section className="mt-8 space-y-6">
            <div className="rounded-3xl border border-teal-200 bg-teal-50 p-6">
              <p className="text-xs font-black uppercase tracking-[0.25em] text-teal-700">
                Seller Battle Verdict
              </p>
              <h2 className="mt-2 text-3xl font-black">{verdict}</h2>
              <p className="mt-3 text-sm font-bold text-slate-700">
                Refund risk comparison: {refundRiskWinner}
              </p>
            </div>

            <div className="grid gap-5 md:grid-cols-2">
              <ScoreCard title="Your Product" result={yourResult} />
              <ScoreCard title="Competitor" result={competitorResult} />
            </div>

            <div className="grid gap-5 md:grid-cols-2">
              <InsightPanel
                title="Where you are losing"
                items={yourResult?.topComplaints}
                fallback="Your biggest repeated complaints will appear here."
              />

              <InsightPanel
                title="Why the competitor may win"
                items={competitorResult?.topPraise}
                fallback="Competitor strengths from review evidence will appear here."
              />

              <InsightPanel
                title="What to fix first"
                items={yourResult?.nextActions}
                fallback="Highest-priority fixes will appear here."
              />

              <InsightPanel
                title="Product fixes"
                items={yourResult?.productFixes}
                fallback="Actual product improvement ideas will appear here."
              />

              <InsightPanel
                title="Listing fixes"
                items={yourResult?.listingFixes}
                fallback="Listing changes to reduce buyer confusion will appear here."
              />

              <InsightPanel
                title="What to advertise"
                items={yourResult?.adAngles}
                fallback="Ad angles based on your product strengths will appear here."
              />
            </div>
          </section>
        )}
      </section>
    </main>
  );
}

function UploadBox({
  eyebrow,
  title,
  file,
  onChange,
}: {
  eyebrow: string;
  title: string;
  file: File | null;
  onChange: (file: File | null) => void;
}) {
  return (
    <label className="rounded-2xl border border-dashed border-teal-300 bg-slate-50 p-6">
      <p className="text-xs font-black uppercase tracking-[0.25em] text-teal-600">
        {eyebrow}
      </p>
      <p className="mt-2 text-xl font-black">{title}</p>
      <input
        className="mt-5 w-full rounded-xl border border-slate-200 bg-white p-3 text-sm font-bold"
        type="file"
        accept=".csv,text/csv"
        onChange={(event) => onChange(event.target.files?.[0] || null)}
      />
      <p className="mt-3 text-sm font-bold text-slate-500">
        {file ? file.name : "No file selected"}
      </p>
    </label>
  );
}

function ScoreCard({ title, result }: { title: string; result: SellerResult | null }) {
  return (
    <div className="rounded-3xl border border-[#d9e2ec] bg-white p-6 shadow-sm">
      <p className="text-xs font-black uppercase tracking-[0.25em] text-slate-500">
        {title}
      </p>

      <div className="mt-4 grid grid-cols-3 gap-3">
        <Metric label="Health" value={score(result?.healthScore)} />
        <Metric label="Satisfaction" value={score(result?.buyerSatisfaction)} />
        <Metric label="Refund Risk" value={score(result?.refundRisk)} />
      </div>

      <p className="mt-5 text-sm font-bold text-slate-600">
        {result?.summary || "Upload CSV to generate seller review analysis."}
      </p>
    </div>
  );
}

function Metric({ label, value }: { label: string; value: string }) {
  return (
    <div className="rounded-2xl bg-slate-50 p-4">
      <p className="text-xs font-black uppercase text-slate-500">{label}</p>
      <p className="mt-2 text-2xl font-black">{value}</p>
    </div>
  );
}

function InsightPanel({
  title,
  items,
  fallback,
}: {
  title: string;
  items?: string[];
  fallback: string;
}) {
  return (
    <div className="rounded-3xl border border-[#d9e2ec] bg-white p-6 shadow-sm">
      <p className="text-xs font-black uppercase tracking-[0.22em] text-teal-600">
        {title}
      </p>

      <ul className="mt-4 space-y-2">
        {(items?.length ? items : [fallback]).slice(0, 5).map((item, index) => (
          <li
            key={`${title}-${index}`}
            className="rounded-xl border border-slate-100 bg-slate-50 p-3 text-sm font-bold text-slate-700"
          >
            {item}
          </li>
        ))}
      </ul>
    </div>
  );
}
